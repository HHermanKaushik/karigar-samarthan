rules_version = '2';

// Suggested starting rules for the collections introduced by the
// UserSyncService / SyncLogger backend-sync fixes.
//
// Deploy with: firebase deploy --only firestore:rules
// (adjust paths in firebase.json if you haven't set up firestore yet)
service cloud.firestore {
  match /databases/{database}/documents {

    // users/{uid} — one profile doc per Firebase Auth user.
    // Only the owning user can read/write their own doc and subcollections.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /products/{productId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      match /orders/{orderId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // sync_errors — write-only diagnostic log from the app (SyncLogger).
    // Clients can create entries but never read or modify existing ones;
    // only trusted backends/admin SDK (which bypass these rules) should
    // read this collection for triage.
    match /sync_errors/{docId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }
  }
}
